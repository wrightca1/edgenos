# EdgeNOS Buildroot configuration for AS5610-52X
# Target: PowerPC e500v2 (P2020)

# Architecture
BR2_powerpc=y
BR2_powerpc_e500v2=y

# Toolchain - use Buildroot's internal toolchain (avoids distro toolchain issues)
BR2_TOOLCHAIN_BUILDROOT=y
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_GCC_VERSION_12_X=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

# System
BR2_TARGET_GENERIC_HOSTNAME="edgenos"
BR2_TARGET_GENERIC_ISSUE="EdgeNOS for AS5610-52X"
BR2_TARGET_GENERIC_GETTY_PORT="ttyS0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE_115200=y
BR2_ROOTFS_OVERLAY="/build/config/rootfs/overlay"
BR2_INIT_SYSTEMD=y
BR2_ROOTFS_POST_BUILD_SCRIPT="/build/config/rootfs/post-build.sh"

# Filesystem
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS4_XZ=y
BR2_TARGET_ROOTFS_TAR=y

# Don't build kernel (we build separately)
BR2_LINUX_KERNEL=n

# Core packages
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_COREUTILS=y
BR2_PACKAGE_BASH=y
BR2_PACKAGE_PROCPS_NG=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_KMOD=y

# Networking
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_IPTABLES=y
BR2_PACKAGE_BRIDGE_UTILS=y
BR2_PACKAGE_ETHTOOL=y
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_DROPBEAR=n
BR2_PACKAGE_TCPDUMP=y
BR2_PACKAGE_WGET=y
BR2_PACKAGE_LIBCURL=y
BR2_PACKAGE_LIBCURL_CURL=y
BR2_PACKAGE_NTP=y

# I2C / Hardware tools
BR2_PACKAGE_I2C_TOOLS=y
BR2_PACKAGE_LMSENSORS=y
BR2_PACKAGE_PCIUTILS=y
BR2_PACKAGE_USBUTILS=y

# Python (for management scripts)
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_READLINE=y

# System utilities
BR2_PACKAGE_RSYNC=y
BR2_PACKAGE_NANO=y
BR2_PACKAGE_LESS=y
BR2_PACKAGE_FILE=y
BR2_PACKAGE_STRACE=y
BR2_PACKAGE_LSOF=y
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_EUDEV=y

# U-Boot tools (for fw_setenv)
BR2_PACKAGE_UBOOT_TOOLS=y
BR2_PACKAGE_UBOOT_TOOLS_FWPRINTENV=y

# Logging
BR2_PACKAGE_LOGROTATE=y
